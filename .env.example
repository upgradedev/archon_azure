# ── Azure Identity ─────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_RESOURCE_GROUP=archon-rg
AZURE_LOCATION=westeurope

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── Azure OpenAI — model deployments ──────────────────────────────────────────
# Deployment for document vision extraction (GPT-4o vision capable)
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o
# Deployment for financial analysis and narrative (GPT-4o or GPT-4o-mini)
AZURE_OPENAI_ANALYSIS_DEPLOYMENT=gpt-4o

# ── Foundry IQ — Azure AI Foundry agent runtime (production path) ─────────────
# When set, the NarratorAgent uses the azure-ai-projects SDK with
# AzureAISearchTool — the full Foundry agent runtime with grounding.
# Format: <endpoint>;<subscription>;<resource-group>;<project-name>
AZURE_AI_PROJECT_CONNECTION_STRING=https://your-foundry.api.azureml.ms;your-sub-id;archon-rg;archon-foundry
# Name of the AI Search connection registered in the Foundry project
AZURE_AI_SEARCH_CONNECTION_NAME=archon-search

# ── Foundry IQ — Azure AI Search (fallback / local dev path) ──────────────────
# Fallback: NarratorAgent uses Azure OpenAI On Your Data (no Foundry runtime).
# Used when AZURE_AI_PROJECT_CONNECTION_STRING is not set.
AZURE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_AI_SEARCH_KEY=your_search_admin_key_here
AZURE_AI_SEARCH_INDEX=archon-knowledge

# ── Azure Blob Storage ─────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=archon

# ── Azure Database for PostgreSQL Flexible Server ─────────────────────────────
POSTGRES_HOST=your-server.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=archon
POSTGRES_USER=archon_admin
POSTGRES_PASSWORD=your_pg_password_here
DATABASE_URL=postgresql://archon_admin:your_pg_password_here@your-server.postgres.database.azure.com:5432/archon

# ── Azure Container Apps ───────────────────────────────────────────────────────
ACA_ENVIRONMENT=archon-env
ACA_EXTRACTION_JOB_NAME=archon-extraction-job
ACA_ANALYSIS_APP_NAME=archon-analysis
ANALYSIS_ENDPOINT_URL=https://archon-analysis.your-env.westeurope.azurecontainerapps.io

# ── Azure Container Registry ──────────────────────────────────────────────────
AZURE_REGISTRY=yourregistry.azurecr.io

# ── Job runner backend (azure | local) ────────────────────────────────────────
JOB_RUNNER_BACKEND=azure

# ── Backend ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Local dev overrides (used by docker compose) ──────────────────────────────
# Azurite (Azure Blob Storage emulator) connection string for local dev
AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
